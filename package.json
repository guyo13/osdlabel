{
  "name": "osdlabel-workspace",
  "version": "0.0.0",
  "author": "Guy Or <guydude1@gmail.com>",
  "private": true,
  "type": "module",
  "packageManager": "pnpm@11.5.1+sha512.k/e1dCLqcGglcjW0wW62B2LraOHcI3IxmcxzkEPqm+LEFDJ0o5nYxt76KxF2Im2cocS2NILWIAwaj7qnjB0UhQ==",
  "scripts": {
    "dev": "turbo dev",
    "build": "turbo build",
    "typecheck": "turbo typecheck",
    "test": "turbo test",
    "test:e2e": "turbo test:e2e",
    "test:all": "turbo run test test:e2e",
    "lint": "turbo lint",
    "format": "prettier --write .",
    "docs:dev": "turbo --filter @osdlabel/docs dev",
    "docs:build": "turbo --filter @osdlabel/docs build",
    "docs:preview": "turbo --filter @osdlabel/docs preview",
    "check-versions": "node scripts/check-versions.js"
  },
  "devDependencies": {
    "@changesets/cli": "^2.31.0",
    "playwright": "^1.58.2",
    "prettier": "catalog:",
    "turbo": "catalog:"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/osdlabel/osdlabel.git"
  }
}
