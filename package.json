{
  "name": "osdlabel-workspace",
  "version": "0.0.0",
  "author": "Guy Or <guydude1@gmail.com>",
  "private": true,
  "type": "module",
  "packageManager": "pnpm@11.5.1+sha512.93f7b57422ea7068257235b4c16eb60762eb68e1dc23723199cc739043ea9be2c4143274a399d8c6defa2b1176226d9ca1c4b63482d6200c1a8fbaa78c1d1485",
  "scripts": {
    "dev": "turbo dev",
    "build": "turbo build",
    "typecheck": "turbo typecheck",
    "test": "turbo test",
    "test:e2e": "turbo test:e2e",
    "test:all": "turbo run test test:e2e",
    "lint": "turbo lint",
    "format": "prettier --write .",
    "docs:dev": "turbo --filter @osdlabel/docs dev",
    "docs:build": "turbo --filter @osdlabel/docs build",
    "docs:preview": "turbo --filter @osdlabel/docs preview",
    "check-versions": "node scripts/check-versions.js"
  },
  "devDependencies": {
    "@changesets/cli": "^2.31.0",
    "playwright": "^1.60.0",
    "prettier": "catalog:",
    "turbo": "catalog:"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/osdlabel/osdlabel.git"
  }
}
